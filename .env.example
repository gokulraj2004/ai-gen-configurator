# ── Application ──
APP_NAME=Configurator
APP_ENV=development
DEBUG=true

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080

# ── Database ──
DB_HOST=db
DB_PORT=5432
DB_NAME=configurator
DB_USER=configurator_user
DB_PASSWORD=change_me_to_a_secure_password

# ── Authentication ──
# Generate a secure random string of at least 32 characters
# Example: openssl rand -base64 48
JWT_SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173